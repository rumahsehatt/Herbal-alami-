{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid",
        "role": { ".write": false }
      }
    },
    "produk": {
      ".read": true,
      ".write": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "pesanan": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$orderId": {
        ".read": "data.child('userId').val() === null || auth !== null",
        ".write": "auth !== null || !data.exists()"
      }
    },
    "testimoni": {
      ".read": true,
      "$testId": {
        ".write": "auth !== null",
        ".delete": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "pengaturan": {
      ".read": true,
      ".write": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "admin_log": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
